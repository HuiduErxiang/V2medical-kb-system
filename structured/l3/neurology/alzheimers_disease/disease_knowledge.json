            "SRC_ITC_ARIA_COMPARISON_2025Q4"
          ]
        },
        {
          "id": "ARI_07",
          "fact": "有症状ARIA(头痛、意识模糊、视觉障碍、癫痫等)需暂停给药，待症状和影像学异常消退后考虑恢复",
          "origin_layer": "L3",
          "source_ids": [
            "SRC_ITC_ARIA_COMPARISON_2025Q4"
          ]
        },
        {
          "id": "ARI_08",
          "fact": "ARIA发生率与疗效可能存在正相关，反映药物对Aβ斑块的清除活性，但需平衡安全性",
          "origin_layer": "L3",
          "source_ids": [
            "SRC_ITC_ARIA_COMPARISON_2025Q4"
          ]
        },
        {
          "id": "ARI_09",
          "fact": "ARIA风险随累积剂量增加而升高，治疗前6个月是ARIA高发期",
          "origin_layer": "L3",
          "source_ids": [
            "SRC_ITC_ARIA_COMPARISON_2025Q4"
          ]
        }
      ]
