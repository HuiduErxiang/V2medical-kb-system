    "caregiver_burden": {
      "category_name": "照护者负担",
      "origin_layer": "L3",
      "facts": [
        {
          "id": "CAR_01",
          "fact": "AD照护者平均每日投入4-8小时进行照护，重度患者照护时间更长，相当于全职工作",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_LANCET_COMMISSION_2020",
            "AD_SRC_ALZ_ASSOC_2025_FACTS"
          ]
        },
        {
          "id": "CAR_02",
          "fact": "照护者抑郁和焦虑发生率高达40-60%，显著高于普通人群，心理健康严重影响生活质量",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_LANCET_COMMISSION_2020"
          ]
        },
        {
          "id": "CAR_03",
          "fact": "照护者因减少工作时间或提前退休导致的收入损失，加上直接照护支出，构成沉重的经济负担",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_LANCET_COMMISSION_2020",
            "AD_SRC_ALZ_ASSOC_2025_FACTS"
          ]
        },
        {
          "id": "CAR_04",
          "fact": "社会隔离是照护者的常见问题，因照护责任限制社交活动，导致孤独感和支持网络减弱",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_LANCET_COMMISSION_2020"
          ]
        },
        {
          "id": "CAR_05",
          "fact": "角色转换困境指配偶或子女从平等关系转变为照护者-被照护者关系，带来情感冲突和心理压力",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_LANCET_COMMISSION_2020"
          ]
        },
        {
          "id": "CAR_06",
          "fact": "照护者支持体系包括喘息服务(respite care)、支持小组、心理咨询和照护技能培训，可显著减轻负担",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_LANCET_COMMISSION_2020",
            "AD_SRC_WHO_2021_DEMENTIA"
          ]
        },
        {
          "id": "CAR_07",
          "fact": "疾病进展导致照护需求增加，重度AD患者需要24小时监护，照护者负担呈进行性加重",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_LANCET_COMMISSION_2020"
          ]
        }
      ]
    },
    "public_misconceptions": {
      "category_name": "公众认知误区",
      "origin_layer": "L3",
      "facts": [
        {
          "id": "MIS_01",
          "fact": "\"老年痴呆\"刻板印象将AD错误地视为正常衰老的一部分，导致患者和家属延误就医和诊断",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_WHO_2021_DEMENTIA",
            "AD_SRC_ALZ_ASSOC_2025_FACTS"
          ]
        },
        {
          "id": "MIS_02",
          "fact": "早发型AD(early-onset AD)指65岁前发病，约占AD病例的5-10%，患者多为在职人群，社会影响更大",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_ALZ_ASSOC_2025_FACTS"
          ]
        },
        {
          "id": "MIS_03",
          "fact": "AD非记忆症状包括执行功能障碍、视空间能力下降、语言障碍和行为改变，常被忽视或误诊",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_SCHELTENS_2021_LANCET"
          ]
        },
        {
          "id": "MIS_04",
          "fact": "\"正常衰老\"与病理性认知下降的区别在于：正常衰老不影响日常生活能力，而AD导致功能进行性丧失",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_SCHELTENS_2021_LANCET"
          ]
        },
        {
          "id": "MIS_05",
          "fact": "早期筛查的可及性正在改善，血液生物标志物检测使大规模筛查成为可能，但仍需提高公众认知",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_HANSSON_2022_BLOOD_BM"
          ]
        },
        {
          "id": "MIS_06",
          "fact": "AD不可治愈的误解导致治疗悲观主义，但DMT的出现证明早期干预可显著延缓疾病进展",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_CUMMINGS_2024_DMT"
          ]
        }
      ]
    },
    "regulatory_landscape": {
      "category_name": "监管环境",
      "origin_layer": "L3",
      "facts": [
        {
          "id": "REG_01",
          "fact": "FDA(美国食品药品监督管理局)、EMA(欧洲药品管理局)和NMPA(中国国家药品监督管理局)是全球三大AD药物监管体系",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_SCHELTENS_2021_LANCET"
          ]
        },
        {
          "id": "REG_02",
          "fact": "加速审批(Accelerated Approval)路径允许基于替代终点(如Aβ清除)批准药物，但需上市后验证临床获益",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_CUMMINGS_2024_DMT"
          ]
        },
        {
          "id": "REG_03",
          "fact": "常规审批(Traditional Approval)要求证实临床终点获益(如认知和功能改善)，证据标准更高",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_CUMMINGS_2024_DMT"
          ]
        },
        {
          "id": "REG_04",
          "fact": "抗Aβ抗体类药物的审批标准存在争议，核心问题是Aβ清除作为替代终点是否能可靠预测临床获益",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_CUMMINGS_2024_DMT"
          ]
        },
        {
          "id": "REG_05",
          "fact": "上市后研究要求(Post-marketing Requirements)是加速审批药物的必要条件，用于确认临床获益和长期安全性",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_CUMMINGS_2024_DMT"
          ]
        },
        {
          "id": "REG_06",
          "fact": "真实世界证据(Real-World Evidence, RWE)在监管决策中的角色日益重要，可补充临床试验数据",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_SCHELTENS_2021_LANCET"
          ]
        },
        {
          "id": "REG_07",
          "fact": "监管指南强调患者分层和个体化治疗，要求明确目标人群(如早期AD、Aβ阳性)",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_JACK_2018_ATAN",
            "AD_SRC_CUMMINGS_2024_DMT"
          ]
        }
      ]
    },
    "competitive_landscape": {
      "category_name": "竞争格局(通用)",
      "origin_layer": "L3",
      "facts": [
        {
          "id": "COM_01",
          "fact": "抗Aβ赛道代表AD治疗范式的根本转变，从症状管理转向疾病修饰，市场潜力巨大",
