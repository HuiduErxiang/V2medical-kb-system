          "source_ids": [
            "AD_SRC_CUMMINGS_2024_DMT"
          ]
        },
        {
          "id": "COM_02",
          "fact": "靶向Aβ的不同策略包括：针对原纤维(fibrils)、斑块(plaques)、可溶性寡聚体(oligomers)或单体(monomers)",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_SELKOE_HARDY_2016",
            "AD_SRC_CUMMINGS_2024_DMT"
          ]
        },
        {
          "id": "COM_03",
          "fact": "间接比较(ITC, Indirect Treatment Comparison)方法学用于跨试验比较不同药物的疗效和安全性，但存在方法学局限性",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_CUMMINGS_2024_DMT"
          ]
        },
        {
          "id": "COM_04",
          "fact": "安全性差异化(尤其是ARIA发生率)是抗Aβ抗体类药物竞争的关键分野，影响临床采用和患者选择",
          "origin_layer": "L3",
          "source_ids": [
            "SRC_ITC_ARIA_COMPARISON_2025Q4"
          ]
        },
        {
          "id": "COM_05",
          "fact": "持续治疗vs可停药的治疗模式之争是抗Aβ抗体领域的重要议题，影响治疗成本和患者依从性",
          "origin_layer": "L3",
          "source_ids": [
            "SRC_CRITIQUE_KAUR_2025Q1_CDI"
          ]
        },
        {
          "id": "COM_06",
          "fact": "给药便利性(如皮下注射vs静脉输注、给药频率)是影响患者偏好和医疗资源利用的差异化因素",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_CUMMINGS_2024_DMT"
          ]
        },
        {
          "id": "COM_07",
          "fact": "生物标志物指导的患者选择策略可优化治疗获益风险比，是精准医疗在AD领域的体现",
          "origin_layer": "L3",
          "source_ids": [
            "AD_SRC_JACK_2018_ATAN",
            "AD_SRC_CUMMINGS_2024_DMT"
          ]
        }
      ]
    }
  }
